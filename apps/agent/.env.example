# PatchGuard agent + capture worker configuration. Copy to .env and fill in.

# Routing services — free OSM-based, no keys needed.
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
OSRM_BASE=https://router.project-osrm.org

# Upstream PatchGuard ERP backend (the YOLOv5 service on :8000).
PATCHGUARD_API_BASE=http://localhost:8000

# Agent control plane.
AGENT_HOST=0.0.0.0
AGENT_PORT=8765

# Shared secret for authenticating worker uploads — must match the backend's WORKER_TOKEN.
WORKER_TOKEN=change-me

# --- Capture worker ---
# Source: streetview (Google, default) | satellite (Esri tiles) | earth (Puppeteer, needs WebGL).
CAPTURE_SOURCE=streetview
# Required for CAPTURE_SOURCE=streetview: Google Maps key with Street View Static API enabled.
GOOGLE_MAPS_API_KEY=
WORKER_HEADLESS=true          # false shows a visible browser window (earth source / demos)
WORKER_SETTLE_MS=1500
WORKER_BATCH_SIZE=15
WORKER_MAX_WAYPOINTS=1000
