FROM python:3.12-slim

WORKDIR /app
COPY apps/agent/pyproject.toml ./
RUN pip install --no-cache-dir uv && uv pip install --system -e .
COPY apps/agent/agent ./agent
COPY apps/agent/api ./api
COPY apps/agent/conftest.py ./

ENV AGENT_HOST=0.0.0.0 AGENT_PORT=8765
EXPOSE 8765
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8765"]
