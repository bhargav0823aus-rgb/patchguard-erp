FROM node:22-bookworm-slim

# Puppeteer needs system Chrome dependencies even though it ships its own browser.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates fonts-liberation libasound2 libatk-bridge2.0-0 libatk1.0-0 \
    libc6 libcairo2 libcups2 libdbus-1-3 libdrm2 libexpat1 libgbm1 libglib2.0-0 \
    libgtk-3-0 libnspr4 libnss3 libpango-1.0-0 libx11-6 libx11-xcb1 libxcb1 \
    libxcomposite1 libxdamage1 libxext6 libxfixes3 libxrandr2 libxss1 libxtst6 \
    wget xdg-utils && rm -rf /var/lib/apt/lists/*

WORKDIR /app/worker
COPY apps/agent/worker/package.json ./
RUN npm install
COPY apps/agent/worker/tsconfig.json ./
COPY apps/agent/worker/src ./src

ENV WORKER_HEADLESS=true
CMD ["npm", "run", "start"]
