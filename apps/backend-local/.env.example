# PatchGuard ERP backend configuration. Copy to .env and fill in.

# --- YOLOv5 model ---
# Absolute path to the trained weights (best.pt) and the cloned yolov5 repo.
MODEL_WEIGHTS=/path/to/runs/train/patchguard/weights/best.pt
YOLOV5_DIR=/path/to/yolov5
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45
INFER_DEVICE=cpu              # or "cuda:0" with a GPU + CUDA torch build

# --- Service ---
HOST=0.0.0.0
PORT=8000
DATA_DIR=./data              # raw/annotated images + invoices land here (gitignored)

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql+asyncpg://patchguard:patchguard@localhost:5432/patchguard

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_HOURS=8
WORKER_TOKEN=change-me        # must match WORKER_TOKEN in apps/agent/.env

# --- Guarantee matching ---
ACTION_MATCH_RADIUS_M=30      # damage within this many metres of a guaranteed path raises an action

# --- Gemini Vision (optional) — captions damaged frames ---
GEMINI_API_KEY=
VISION_ENABLED=true
VISION_MODEL=gemini-2.5-flash

# --- Claude inspection reports ---
REPORT_MODE=mock             # mock (template, no API call) | claude
ANTHROPIC_API_KEY=
REPORT_MODEL=claude-haiku-4-5
